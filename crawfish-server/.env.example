# SQLite for dev (zero setup). Swap to Postgres in prod via Neon/Supabase/etc.
DATABASE_URL="file:./dev.db"

# Optional: when set, real emails are sent via Resend (invites). Otherwise
# invite URLs are console.logged. Get key at https://resend.com/api-keys
# RESEND_API_KEY="re_..."

# Optional: when set, Clerk JWTs are verified. When unset, the auth
# middleware trusts X-User-Id from any request (dev mode). Get key at
# https://dashboard.clerk.com/last-active?path=api-keys
# CLERK_SECRET_KEY="sk_test_..."

# Server port
PORT=7882
