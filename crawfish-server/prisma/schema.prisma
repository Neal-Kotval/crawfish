generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"   // swap to postgresql for prod
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  clerkId    String?  @unique   // null in dev mode
  email      String   @unique
  name       String?
  createdAt  DateTime @default(now())
  orgs       OrgMember[]
  invitesSent Invite[] @relation("InvitesSentByUser")
}

model Org {
  id             String   @id @default(cuid())
  name           String   @unique         // matches the on-disk folder name
  project        String?
  teamSize       String?
  primaryClient  String?
  createdAt      DateTime @default(now())
  members        OrgMember[]
  agents         AgentMeta[]
  sessions       Session[]
  deviceCodes    DeviceLinkCode[]
  invites        Invite[]
}

model OrgMember {
  id        String   @id @default(cuid())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String   @default("contributor")   // founder | contributor | viewer
  createdAt DateTime @default(now())

  @@unique([orgId, userId])
}

// Agent metadata mirrored from the Dash on-disk org. Files stay local;
// this is just enough for the read-only online canvas.
model AgentMeta {
  id        String   @id @default(cuid())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  name      String                            // matches the YAML filename
  role      String
  runtime   String
  hiredAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
}

// Sessions are metadata-only on the server (transcripts stay in lens).
model Session {
  id        String   @id @default(cuid())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  agentName String
  task      String
  costUsd   Float    @default(0)
  totalTokens Int    @default(0)
  status    String   @default("running")   // running | completed | failed
  isPublic  Boolean  @default(false)       // public permalink
  startedAt DateTime @default(now())
  endedAt   DateTime?
}

// Short-lived code generated by the platform, redeemed by Dash to bind
// a local org to a server-side Org row.
model DeviceLinkCode {
  code      String   @id                    // 6 uppercase alphanumeric
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  expiresAt DateTime
  redeemedAt DateTime?
  redeemedByUserId String?
}

model Invite {
  id        String   @id @default(cuid())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  email     String
  token     String   @unique
  sentBy    User     @relation("InvitesSentByUser", fields: [sentByUserId], references: [id])
  sentByUserId String
  acceptedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
}
