{
  "name": "crawfish-opt-artifact",
  "version": "0.1.0",
  "description": "Artifact MCP server — durable-reference returns. Big tool results write to ~/.crawfish/artifacts/ and the model gets a tiny envelope instead of the whole payload.",
  "type": "module",
  "bin": {
    "crawfish-opt-artifact": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "bench": "tsc && node dist/bench/run.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["mcp", "claude", "tokens", "artifact", "ai-agent"],
  "license": "MIT",
  "crawfish-contract": "1.0"
}
