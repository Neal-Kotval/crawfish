generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"   // swap to postgresql for prod
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  clerkId    String?  @unique   // null in dev mode
  email      String   @unique
  name       String?
  createdAt  DateTime @default(now())
  orgs       OrgMember[]
  invitesCreated Invite[] @relation("InvitesCreatedByUser")
  invitesRedeemed Invite[] @relation("InvitesRedeemedByUser")
}

model Org {
  id             String   @id @default(cuid())
  name           String   @unique         // matches the on-disk folder name
  project        String?
  teamSize       String?
  primaryClient  String?
  createdAt      DateTime @default(now())
  members        OrgMember[]
  agents         AgentMeta[]
  sessions       Session[]
  deviceCodes    DeviceLinkCode[]
  invites        Invite[]
  projects       Project[]
  integrations   Integration[]
}

model OrgMember {
  id        String   @id @default(cuid())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String   @default("contributor")   // founder | contributor | viewer
  createdAt DateTime @default(now())

  @@unique([orgId, userId])
}

// Agent metadata mirrored from the Dash on-disk org. Files stay local;
// this is just enough for the read-only online canvas.
model AgentMeta {
  id        String   @id @default(cuid())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  name      String                            // matches the YAML filename
  role      String
  runtime   String
  hiredAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
}

// Sessions are metadata-only on the server (transcripts stay in lens).
model Session {
  id        String   @id @default(cuid())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  agentName String
  task      String
  costUsd   Float    @default(0)
  totalTokens Int    @default(0)
  status    String   @default("running")   // running | completed | failed
  isPublic  Boolean  @default(false)       // public permalink
  startedAt DateTime @default(now())
  endedAt   DateTime?
}

// Short-lived code generated by the platform, redeemed by Dash to bind
// a local org to a server-side Org row.
model DeviceLinkCode {
  code      String   @id                    // 6 uppercase alphanumeric
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  expiresAt DateTime
  redeemedAt DateTime?
  redeemedByUserId String?
  authToken String?                          // JWT minted at redeem time; polled by Dash, then deleted
}

model Invite {
  id        String   @id @default(cuid())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  email     String
  role      String   @default("contributor")   // owner | contributor
  code      String   @unique
  createdBy User     @relation("InvitesCreatedByUser", fields: [createdById], references: [id])
  createdById String
  createdAt DateTime @default(now())
  expiresAt DateTime
  redeemedAt DateTime?
  redeemedBy User?   @relation("InvitesRedeemedByUser", fields: [redeemedById], references: [id])
  redeemedById String?
}

model Project {
  id              String   @id @default(cuid())
  org             Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId           String
  name            String
  githubRepo      String?
  githubRepoId    Int?
  defaultBranch   String?
  isPrivate       Boolean  @default(false)
  cloneStatus     String   @default("pending")
  cloneError      String?
  localPath       String?
  deviceId        String?
  linearTeamId    String?
  linearTeamKey   String?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  issues          Issue[]
  tasks           Task[]
  cycles          Cycle[]
  epics           Epic[]
  activities      Activity[]

  @@unique([orgId, githubRepoId], name: "org_repo_unique")
}

// Per-org, per-provider OAuth connection. Holds the access/refresh tokens used
// to pull issues from GitHub and Linear. Tokens are plaintext this phase
// (encryption-at-rest is a tracked follow-up); never serialize them in an API
// response, never log them.
model Integration {
  id                    String   @id @default(cuid())
  org                   Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId                 String
  provider              String                       // "github" | "linear" (enforced in app-layer zod)
  accessToken           String
  refreshToken          String?
  externalWorkspaceId   String?                      // Linear org id
  externalWorkspaceName String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([orgId, provider])
}

// An issue synced from a provider into a Project. sqlite has no array/JSON
// type, so `labels` is a JSON-encoded string. Idempotent re-sync upserts on
// the (projectId, provider, externalId) compound key.
model Issue {
  id                String    @id @default(cuid())
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId         String
  provider          String                          // "github" | "linear" (provider mirror; authored work is a Task)
  externalId        String                          // stable provider node id (unique-key component)
  externalKey       String                          // human id: "ENG-123" (Linear) | "#42" (GitHub)
  number            Int?
  title             String
  body              String?
  state             String                          // normalized "open" | "closed"
  url               String?
  labels            String    @default("[]")        // JSON-encoded array of label names
  assigneeExternal  String?
  externalUpdatedAt DateTime?
  syncedAt          DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([projectId, provider, externalId])
}

// ─── Canonical board domain model (ADR-003) ─────────────────────────────────
// Cloud Postgres is the source of truth. `Task` is the authored work item;
// distinct from `Issue` (external provider mirror). Statuses/roles are the
// canonical vocabularies enforced in src/domain/contract.ts (sqlite has no
// enum type). All board entities are project-scoped.

// A time-boxed iteration (sprint) for a project.
model Cycle {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  name      String
  status    String   @default("upcoming")   // upcoming | active | completed
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

// A larger body of work grouping tasks.
model Epic {
  id          String  @id @default(cuid())
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String
  description String?
  status      String   @default("backlog")  // canonical TaskStatus
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
}

// The authored board work item. `status` is the canonical TaskStatus;
// `escalated` is an orthogonal flag (ADR-003) so budget breaches never write
// a status the board rejects.
model Task {
  id            String   @id @default(cuid())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  title         String
  description   String?
  status        String   @default("triage")  // triage|backlog|in_progress|in_review|blocked|done|canceled
  escalated     Boolean  @default(false)
  cycle         Cycle?   @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  cycleId       String?
  epic          Epic?    @relation(fields: [epicId], references: [id], onDelete: SetNull)
  epicId        String?
  assigneeId    String?                       // OrgMember.id (human or agent member)
  tokenBudget   Int?
  tokensSpent   Int      @default(0)
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  criteria      AcceptanceCriterion[]
  linksFrom     TaskLink[] @relation("LinkFrom")
  linksTo       TaskLink[] @relation("LinkTo")
  activities    Activity[]
}

// Acceptance criterion on a task (Phase 5 builds the evidence guard on this).
model AcceptanceCriterion {
  id          String   @id @default(cuid())
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String
  kind        String                          // test | manual | spec_match
  description String
  met         Boolean  @default(false)
  evidence    String?                         // JSON-encoded payload when met
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Typed link between two tasks (Phase 7 renders the graph on this).
model TaskLink {
  id         String  @id @default(cuid())
  fromTask   Task    @relation("LinkFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  fromTaskId String
  toTask     Task    @relation("LinkTo", fields: [toTaskId], references: [id], onDelete: Cascade)
  toTaskId   String
  kind       String                           // blocks | depends_on | duplicates | relates_to | subtask_of
  createdAt  DateTime @default(now())

  @@unique([fromTaskId, toTaskId, kind])
}

// Append-only activity feed entry. `payload` is a JSON-encoded string (sqlite).
model Activity {
  id            String   @id @default(cuid())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  task          Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId        String?
  actorMemberId String?                        // OrgMember.id; null = system
  kind          String                         // task_created | status_changed | assigned | ...
  payload       String   @default("{}")        // JSON-encoded
  createdAt     DateTime @default(now())
}
